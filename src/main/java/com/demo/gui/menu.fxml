<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="menuPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.demo.gui.controller.MenuController">
   <children>
      <Label alignment="CENTER" layoutX="6.0" layoutY="78.0" prefHeight="58.0" prefWidth="600.0" text="Who wants to be a millionaire?">
         <font>
            <Font size="40.0" />
         </font>
      </Label>
      <VBox alignment="CENTER" layoutX="150.0" layoutY="148.0" prefHeight="200.0" prefWidth="300.0" spacing="15.0" style="-fx-background-color: #2626cc; -fx-border-color: black; -fx-border-radius: 5px; -fx-border-width: 5px;">
         <children>
            <Button fx:id="startBtn" mnemonicParsing="false" onAction="#startGame" text="💸 Start" textAlignment="CENTER">
               <font>
                  <Font size="20.0" />
               </font>
            </Button>
            <Button fx:id="leaderboardBtn" mnemonicParsing="false" onAction="#showLeaderboard" text="📓 Leaderboard" textAlignment="CENTER">
               <font>
                  <Font size="20.0" />
               </font>
            </Button>
            <Button fx:id="quitBtn" mnemonicParsing="false" onAction="#quitGame" text="🔚 Quit" textAlignment="CENTER">
               <font>
                  <Font size="20.0" />
               </font>
            </Button>
         </children>
         <padding>
            <Insets top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
